# ─── Application ──────────────────────────────────────────────────────────────
BASE_URL=https://playonkansas.com
API_BASE_URL=https://playonkansas.com/api

# ─── Authentication ────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password

TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=your_test_password

# ─── Environment ───────────────────────────────────────────────────────────────
# Options: local | dev | staging | production
ENV=local

# ─── QMetry Cloud Reporting ────────────────────────────────────────────────────
# Generate your API key: QMetry Cloud → Settings → API Keys
# Leave QMETRY_API_KEY blank to disable reporting (safe for local runs).
QMETRY_API_KEY=
QMETRY_PROJECT_KEY=POK
QMETRY_CYCLE_NAME=Automated Run
